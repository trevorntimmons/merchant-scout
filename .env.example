# Required — Google Places API (New): https://developers.google.com/maps/documentation/places/web-service/op-overview
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional — enables a natural-language history/angle write-up per prospect
# instead of the templated one. Falls back silently if unset.
ANTHROPIC_API_KEY=

# Optional — hours to cache Places API responses locally before re-querying
CACHE_TTL_HOURS=24
